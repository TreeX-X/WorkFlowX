{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "memory": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@modelcontextprotocol/server-memory"],
      "environment": {
        "MEMORY_FILE_PATH": "${MCP_MEMORY_FILE_PATH}"
      },
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    }
  },
  "agent": {
    "coderX": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "deny",
        "skill": "allow",
        "todowrite": "allow"
      }
    },
    "evaluatorX": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "deny",
        "skill": "allow",
        "todowrite": "allow"
      }
    },
    "promptMasterX": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "task": "deny",
        "skill": "allow"
      }
    },
    "abstracterX": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "task": "deny",
        "skill": "allow"
      }
    }
  },
  "command": {
    "xwhole": {
      "description": "Full-repo workflow: PRD planning -> coderX -> evaluatorX loop",
      "agent": "build",
      "subtask": true,
      "template": ".opencode/commands/xwhole.md"
    },
    "xlocal": {
      "description": "Local module workflow: skip PRD -> promptMasterX -> coderX -> evaluatorX loop",
      "agent": "build",
      "subtask": true,
      "template": ".opencode/commands/xlocal.md"
    },
    "xunit": {
      "description": "Minimal unit task: promptMasterX -> coderX, no evaluation",
      "agent": "build",
      "subtask": true,
      "template": ".opencode/commands/xunit.md"
    },
    "xprompt": {
      "description": "Prompt optimization only, no development workflow",
      "agent": "promptMasterX",
      "subtask": true,
      "template": ".opencode/commands/xprompt.md"
    },
    "xstatus": {
      "description": "Generate huashu-styled HTML workflow status report and open in browser",
      "agent": "build",
      "subtask": true,
      "template": ".opencode/commands/xstatus.md"
    }
  }
}
