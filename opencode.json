{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["workflowx@git+https://github.com/TreeX/workflowx.git"],
  "mcp": {
    "memory": {
      "type": "local",
      "command": ["mcp-server-memory"],
      "environment": {
        "MEMORY_FILE_PATH": "C:/Users/77777/.cache/mcp-memory/memory.json"
      },
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["mcp-server-sequential-thinking"],
      "enabled": true
    }
  },
  "agent": {
    "orchestratorX": {
      "description": "WorkflowX core orchestration agent. Sole document writer. Coordinates planning dialogue, coderX, evaluatorX across xwhole/xlocal/xunit modes.",
      "mode": "primary",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": {
          "*": "deny",
          "coderX": "allow",
          "evaluatorX": "allow",
          "promptMasterX": "allow",
          "abstracterX": "allow",
          "general": "allow",
          "explore": "allow"
        },
        "skill": "allow",
        "todowrite": "allow",
        "webfetch": "allow"
      }
    },
    "coderX": {
      "description": "Lean coding agent. Owns implementation of features, bug fixes, refactors, and tests. Applies karpathy-guidelines and codex-spec-implementation skills.",
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "deny",
        "skill": "allow",
        "todowrite": "allow"
      }
    },
    "evaluatorX": {
      "description": "Lean code audit and evaluation agent. Reads Parent+Child hybrid docs, inspects git diffs and project code, produces structured evaluation reports.",
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "deny",
        "skill": "allow",
        "todowrite": "allow"
      }
    },
    "promptMasterX": {
      "description": "Prompt preprocessing agent. Receives raw requirement text, identifies the target tool, and outputs an optimized production-grade prompt.",
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "task": "deny",
        "skill": "allow"
      }
    },
    "abstracterX": {
      "description": "Code and engineering analysis agent. Produces structured Markdown code summarization and analysis reports.",
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "task": "deny",
        "skill": "allow"
      }
    }
  },
  "command": {
    "xwhole": {
      "description": "Full-repo workflow: PRD planning -> coderX -> evaluatorX loop",
      "agent": "orchestratorX",
      "subtask": true,
      "template": ".opencode/commands/xwhole.md"
    },
    "xlocal": {
      "description": "Local module workflow: skip PRD -> promptMasterX -> coderX -> evaluatorX loop",
      "agent": "orchestratorX",
      "subtask": true,
      "template": ".opencode/commands/xlocal.md"
    },
    "xunit": {
      "description": "Minimal unit task: promptMasterX -> coderX, no evaluation",
      "agent": "orchestratorX",
      "subtask": true,
      "template": ".opencode/commands/xunit.md"
    },
    "xprompt": {
      "description": "Prompt optimization only, no development workflow",
      "agent": "promptMasterX",
      "subtask": true,
      "template": ".opencode/commands/xprompt.md"
    }
  }
}
