{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["workflowx@git+https://github.com/TreeX/workflowx.git"],
  "mcp": {
    "memory": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@modelcontextprotocol/server-memory"],
      "environment": {
        "MEMORY_FILE_PATH": "${MCP_MEMORY_FILE_PATH}"
      },
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    }
  },
  "agent": {
    "orchestratorX": {
      "mode": "primary",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": {
          "*": "deny",
          "coderX": "allow",
          "evaluatorX": "allow",
          "promptMasterX": "allow",
          "abstracterX": "allow",
          "general": "allow",
          "explore": "allow"
        },
        "skill": "allow",
        "todowrite": "allow",
        "webfetch": "allow"
      }
    },
    "coderX": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "deny",
        "skill": "allow",
        "todowrite": "allow"
      }
    },
    "evaluatorX": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "deny",
        "skill": "allow",
        "todowrite": "allow"
      }
    },
    "promptMasterX": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "task": "deny",
        "skill": "allow"
      }
    },
    "abstracterX": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "task": "deny",
        "skill": "allow"
      }
    }
  },
  "command": {
    "xwhole": {
      "description": "Full-repo workflow: PRD planning -> coderX -> evaluatorX loop",
      "agent": "orchestratorX",
      "subtask": true,
      "template": ".opencode/commands/xwhole.md"
    },
    "xlocal": {
      "description": "Local module workflow: skip PRD -> promptMasterX -> coderX -> evaluatorX loop",
      "agent": "orchestratorX",
      "subtask": true,
      "template": ".opencode/commands/xlocal.md"
    },
    "xunit": {
      "description": "Minimal unit task: promptMasterX -> coderX, no evaluation",
      "agent": "orchestratorX",
      "subtask": true,
      "template": ".opencode/commands/xunit.md"
    },
    "xprompt": {
      "description": "Prompt optimization only, no development workflow",
      "agent": "promptMasterX",
      "subtask": true,
      "template": ".opencode/commands/xprompt.md"
    },
    "xstatus": {
      "description": "Generate huashu-styled HTML workflow status report and open in browser",
      "agent": "orchestratorX",
      "subtask": true,
      "template": ".opencode/commands/xstatus.md"
    }
  }
}
